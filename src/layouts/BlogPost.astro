---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import ReadingTime from '../components/ReadingTime.astro';
import TableOfContents from '../components/TableOfContents.astro';
import SeriesNav from '../components/SeriesNav.astro';
import Giscus from '../components/Giscus.astro';
import { getPostSlug } from '../lib/posts';

interface Props {
  post: CollectionEntry<'blog'>;
  headings: { depth: number; slug: string; text: string }[];
  rawContent: string;
  seriesPosts?: CollectionEntry<'blog'>[];
}

const { post, headings, rawContent, seriesPosts = [] } = Astro.props;
const { title, description, pubDate, updatedDate, tags, lang, heroImage, series } = post.data;

const dateFmt = (d: Date) =>
  d.toLocaleDateString(lang === 'vi' ? 'vi-VN' : 'en-US', {
    year: 'numeric', month: 'long', day: 'numeric',
  });
---

<BaseLayout title={title} description={description} lang={lang} ogImage={heroImage}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-3 text-sm text-[var(--color-text-dim)] mb-4">
        <time datetime={pubDate.toISOString()}>{dateFmt(pubDate)}</time>
        {updatedDate && <span>· Updated {dateFmt(updatedDate)}</span>}
        <span>·</span>
        <ReadingTime content={rawContent} lang={lang} />
      </div>

      <h1 class="text-3xl md:text-4xl font-bold mb-4">{title}</h1>
      <p class="text-lg text-[var(--color-text-dim)]">{description}</p>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map(tag => (
            <a href={`/${lang}/tags/${tag}`}
               class="text-xs font-mono px-2 py-1 rounded bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-text-dim)] hover:text-[var(--color-accent)] transition-colors">
              #{tag}
            </a>
          ))}
        </div>
      )}
    </header>

    {series && seriesPosts.length > 0 && (
      <SeriesNav
        currentSlug={getPostSlug(post)}
        series={series}
        lang={lang}
        seriesPosts={seriesPosts}
      />
    )}

    {heroImage && (
      <img src={heroImage} alt={title} class="w-full rounded-lg mb-10" loading="eager" />
    )}

    <TableOfContents headings={headings} />

    <div class="prose prose-lg max-w-none">
      <slot />
    </div>

    <footer class="mt-12 pt-6 border-t border-[var(--color-border)] flex items-center justify-between">
      <div class="flex flex-wrap gap-2">
        {tags.map(tag => (
          <a href={`/${lang}/tags/${tag}`}
             class="text-xs font-mono px-2 py-1 rounded bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-text-dim)] hover:text-[var(--color-accent)]">
            #{tag}
          </a>
        ))}
      </div>
      <a href={`/${lang}/blog`} class="text-sm text-[var(--color-accent)] hover:underline">
        {lang === 'vi' ? '← Về blog' : '← Back to blog'}
      </a>
    </footer>

    <Giscus />
  </article>
</BaseLayout>

<script type="module">
  if (document.querySelector('.mermaid')) {
    const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');

    const isDark = !document.documentElement.classList.contains('light');

    mermaid.initialize({
      startOnLoad: true,
      theme: 'base',
      themeVariables: isDark ? {
        primaryColor: '#1e293b',
        primaryTextColor: '#e2e8f0',
        primaryBorderColor: '#334155',
        lineColor: '#38bdf8',
        secondaryColor: '#0f172a',
        tertiaryColor: '#1e293b',
        noteBkgColor: '#1e293b',
        noteTextColor: '#94a3b8',
        noteBorderColor: '#334155',
        actorBkg: '#1e293b',
        actorTextColor: '#e2e8f0',
        actorBorder: '#334155',
        actorLineColor: '#38bdf8',
        signalColor: '#e2e8f0',
        signalTextColor: '#e2e8f0',
        fontFamily: 'IBM Plex Mono, monospace',
        fontSize: '13px',
      } : {
        primaryColor: '#f0f4fa',
        primaryTextColor: '#1e293b',
        primaryBorderColor: '#e2e8f0',
        lineColor: '#0284c7',
        secondaryColor: '#f8fafc',
        tertiaryColor: '#ffffff',
        noteBkgColor: '#f8fafc',
        noteTextColor: '#64748b',
        noteBorderColor: '#e2e8f0',
        actorBkg: '#ffffff',
        actorTextColor: '#1e293b',
        actorBorder: '#e2e8f0',
        actorLineColor: '#0284c7',
        signalColor: '#1e293b',
        signalTextColor: '#1e293b',
        fontFamily: 'IBM Plex Mono, monospace',
        fontSize: '13px',
      },
      flowchart: { curve: 'basis', padding: 20 },
      sequence: { actorMargin: 50, messageMargin: 40 },
    });
  }
</script>
