---
interface StripItem {
  code: string;
  title: string;
  note: string;
  tone?: 'teal' | 'blue' | 'rust' | 'red';
}

interface Props {
  items: StripItem[];
}

const { items } = Astro.props;

const tones = {
  teal: '#0f766e',
  blue: '#2563eb',
  rust: '#c2410c',
  red: '#b91c1c',
};
---

<div class="langgraph-control-strip not-prose">
  {items.map((item, index) => {
    const tone = tones[item.tone || 'teal'];
    return (
      <article class="langgraph-control-strip__item" style={`--strip-tone:${tone};`}>
        <div class="langgraph-control-strip__index">{String(index + 1).padStart(2, '0')}</div>
        <div class="langgraph-control-strip__body">
          <p class="langgraph-control-strip__code">{item.code}</p>
          <h3>{item.title}</h3>
          <p class="langgraph-control-strip__note">{item.note}</p>
        </div>
      </article>
    );
  })}
</div>

<style>
  .langgraph-control-strip {
    display: grid;
    gap: 0.75rem;
  }

  .langgraph-control-strip__item {
    display: grid;
    grid-template-columns: 3.1rem 1fr;
    gap: 0.9rem;
    align-items: start;
    padding: 0.95rem 1rem;
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--strip-tone) 18%, transparent);
    background: rgba(255, 251, 244, 0.82);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }

  .langgraph-control-strip__index {
    display: grid;
    place-items: center;
    width: 3.1rem;
    height: 3.1rem;
    border-radius: 0.9rem;
    background: color-mix(in srgb, var(--strip-tone) 14%, white);
    color: var(--strip-tone);
    font: 700 0.88rem/1 "IBM Plex Mono", monospace;
    letter-spacing: 0.12em;
  }

  .langgraph-control-strip__body {
    display: grid;
    gap: 0.28rem;
  }

  .langgraph-control-strip__code {
    margin: 0;
    color: var(--strip-tone);
    font: 700 0.68rem/1.2 "IBM Plex Mono", monospace;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .langgraph-control-strip__body h3 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.15;
    color: #17212b;
  }

  .langgraph-control-strip__note {
    margin: 0;
    color: #475569;
    font-size: 0.9rem;
    line-height: 1.55;
  }
</style>
