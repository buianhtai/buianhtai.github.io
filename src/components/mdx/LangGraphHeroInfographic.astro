<section class="langgraph-hero not-prose" aria-labelledby="langgraph-hero-title">
  <div class="langgraph-hero__header">
    <p class="langgraph-hero__eyebrow">Inside the LangGraph Runtime</p>
    <h2 id="langgraph-hero-title">State moves through the system. The prompt does not.</h2>
    <p class="langgraph-hero__lede">
      LangGraph works like a control machine for long-running agent workflows: routing is explicit, interrupts are
      intentional, and durability sits underneath every step.
    </p>
  </div>

  <div class="langgraph-hero__poster">
    <svg
      class="langgraph-hero__svg"
      viewBox="0 0 1240 860"
      role="img"
      aria-label="Retro-industrial LangGraph infographic showing state moving across routing rails with human interrupts and durability systems below."
    >
      <defs>
        <linearGradient id="lg-bg" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#f5ecd9" />
          <stop offset="100%" stop-color="#e4d2b2" />
        </linearGradient>
        <linearGradient id="lg-steel" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#293240" />
          <stop offset="100%" stop-color="#51606f" />
        </linearGradient>
        <linearGradient id="lg-track" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#0f766e" />
          <stop offset="100%" stop-color="#2563eb" />
        </linearGradient>
        <linearGradient id="lg-rust" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#b45309" />
          <stop offset="100%" stop-color="#ea580c" />
        </linearGradient>
        <filter id="lg-glow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="8" result="blur" />
          <feMerge>
            <feMergeNode in="blur" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
      </defs>

      <rect x="12" y="12" width="1216" height="836" rx="36" fill="url(#lg-bg)" />
      <rect x="28" y="28" width="1184" height="804" rx="28" class="langgraph-panel" />

      <g class="langgraph-grid">
        <path d="M108 150 H1132" />
        <path d="M108 210 H1132" />
        <path d="M108 270 H1132" />
        <path d="M108 330 H1132" />
        <path d="M108 390 H1132" />
        <path d="M108 450 H1132" />
        <path d="M108 510 H1132" />
        <path d="M108 570 H1132" />
      </g>

      <text x="92" y="98" class="langgraph-stencil langgraph-stencil--small">LANGGRAPH OPERATING YARD</text>
      <text x="92" y="132" class="langgraph-title">A stateful runtime for durable agent control flow</text>

      <g class="langgraph-zone-label">
        <text x="112" y="194">INPUT / ROUTE</text>
        <text x="470" y="194">GRAPH FLOOR</text>
        <text x="926" y="194">EXECUTION SURFACES</text>
      </g>

      <g class="langgraph-track-bed">
        <path d="M140 252 H430" />
        <path d="M430 252 H615" />
        <path d="M615 252 H805" />
        <path d="M805 252 H1030" />
        <path d="M615 252 C700 252 710 336 805 336" />
        <path d="M805 336 H1030" />
        <path d="M430 252 C505 252 515 168 615 168" />
        <path d="M615 168 H860" />
      </g>

      <g class="langgraph-track-pulse">
        <path d="M152 252 H1016" />
        <path d="M615 252 C700 252 710 336 805 336" />
      </g>

      <g class="langgraph-switch">
        <circle cx="615" cy="252" r="24" />
        <path d="M604 242 L626 262" />
        <path d="M626 242 L604 262" />
      </g>

      <g class="langgraph-station langgraph-station--route">
        <rect x="140" y="216" width="170" height="72" rx="18" />
        <text x="165" y="246">PLAN / ROUTE</text>
        <text x="165" y="270" class="langgraph-station__sub">Intent split, policy check, edge selection</text>
      </g>

      <g class="langgraph-station langgraph-station--graph">
        <rect x="430" y="212" width="185" height="80" rx="24" />
        <text x="458" y="244">STATEGRAPH CORE</text>
        <text x="458" y="272" class="langgraph-station__sub">Nodes, reducers, conditional edges</text>
      </g>

      <g class="langgraph-station langgraph-station--tool">
        <rect x="805" y="212" width="225" height="80" rx="24" />
        <text x="835" y="244">TOOLS / MODELS</text>
        <text x="835" y="272" class="langgraph-station__sub">Execution ports, retrieval, generation</text>
      </g>

      <g class="langgraph-station langgraph-station--review">
        <rect x="805" y="296" width="225" height="80" rx="24" />
        <text x="837" y="328">REVIEW / VERIFY</text>
        <text x="837" y="356" class="langgraph-station__sub">Quality gates, final checks, answer shaping</text>
