      <g class="langgraph-durability-base">
        <rect x="92" y="610" width="1056" height="150" rx="28" />
        <text x="128" y="650" class="langgraph-stencil">DURABILITY FOUNDATION</text>

        <g class="langgraph-vault langgraph-vault--checkpoints">
          <rect x="132" y="672" width="240" height="58" rx="18" />
          <text x="160" y="706">CHECKPOINT VAULT</text>
        </g>

        <g class="langgraph-vault langgraph-vault--threads">
          <rect x="402" y="672" width="240" height="58" rx="18" />
          <text x="438" y="706">THREAD HISTORY</text>
        </g>

        <g class="langgraph-vault langgraph-vault--memory">
          <rect x="672" y="672" width="240" height="58" rx="18" />
          <text x="719" y="706">MEMORY RESERVOIR</text>
        </g>

        <g class="langgraph-vault langgraph-vault--resume">
          <rect x="942" y="672" width="170" height="58" rx="18" />
          <text x="972" y="706">RESUME</text>
        </g>
      </g>

      <g class="langgraph-telemetry">
        <g transform="translate(120 514)">
          <circle cx="0" cy="0" r="18" />
          <path d="M-8 5 L-2 -6 L4 0 L9 -10" />
