---
import Label from './Label.astro';

interface Props {
  id: string;
  kicker?: string;
  title: string;
  color?: 'teal' | 'green' | 'amber' | 'rose';
  summary?: string;
}

const {
  id,
  kicker,
  title,
  color = 'teal',
  summary,
} = Astro.props;
---

<section class="slide-panel not-prose" data-slide={id} id={id}>
  <div class={`slide-panel__shell slide-panel__shell--${color}`}>
    <header class="slide-panel__header">
      <div class="slide-panel__titles">
        {kicker && <Label color={color}>{kicker}</Label>}
        <h2>{title}</h2>
        {summary && <p class="slide-panel__summary">{summary}</p>}
      </div>
    </header>

    <div class="slide-panel__body">
      <slot />
    </div>
  </div>
</section>

<style>
  .slide-panel {
    min-height: 90svh;
    scroll-margin-top: 5rem;
    display: grid;
    align-items: center;
  }

  .slide-panel__shell {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    padding: 2.2rem;
    background:
      radial-gradient(circle at top right, rgba(56, 189, 248, 0.12), transparent 26%),
      linear-gradient(180deg, color-mix(in srgb, var(--color-surface) 95%, transparent), var(--color-surface));
    box-shadow: 0 28px 80px rgba(15, 23, 42, 0.18);
  }

  .slide-panel__shell::after {
    content: '';
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    height: 5px;
    opacity: 0.9;
  }

  .slide-panel__shell--teal::after {
    background: linear-gradient(90deg, #0891b2, transparent 75%);
  }

  .slide-panel__shell--green::after {
    background: linear-gradient(90deg, #059669, transparent 75%);
  }

  .slide-panel__shell--amber::after {
    background: linear-gradient(90deg, #d97706, transparent 75%);
  }

  .slide-panel__shell--rose::after {
    background: linear-gradient(90deg, #be123c, transparent 75%);
  }

  .slide-panel__header {
    margin-bottom: 1.35rem;
  }

  .slide-panel__titles {
    display: grid;
    gap: 0.85rem;
    max-width: 60rem;
  }

  .slide-panel__header h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.8rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
  }

  .slide-panel__summary {
    margin: 0;
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    line-height: 1.6;
    color: var(--color-text-dim);
    max-width: 52rem;
  }

  .slide-panel__body {
    display: grid;
    gap: 1.25rem;
  }

  @media (max-width: 959px) {
    .slide-panel {
      min-height: auto;
    }

    .slide-panel__shell {
      border-radius: 1.5rem;
      padding: 1.25rem;
    }

    .slide-panel__titles {
      gap: 0.75rem;
    }

    .slide-panel__header h2 {
      font-size: clamp(1.6rem, 9vw, 2.5rem);
    }
  }
</style>
