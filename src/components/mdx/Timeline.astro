---
interface Props {
  events: Array<{
    date: string;
    title: string;
    description?: string;
    color?: 'teal' | 'green' | 'amber' | 'rose';
    highlight?: boolean;
  }>;
  direction?: 'vertical' | 'horizontal';
}

const { events, direction = 'vertical' } = Astro.props;

const fgColors: Record<string, string> = {
  teal:  '#0891b2',
  green: '#059669',
  amber: '#d97706',
  rose:  '#be123c',
};

const bgColors: Record<string, string> = {
  teal:  'rgba(8,145,178,0.12)',
  green: 'rgba(5,150,105,0.12)',
  amber: 'rgba(217,119,6,0.12)',
  rose:  'rgba(190,18,60,0.12)',
};
---

<div class={`tl-container tl-${direction}`}>
  {events.map((event, i) => {
    const color = event.color || 'teal';
    const fg = fgColors[color];
    const bg = bgColors[color];
    const isLast = i === events.length - 1;

    return (
      <div class={`tl-event${isLast ? ' tl-event--last' : ''}${event.highlight ? ' tl-event--hl' : ''}`}>
        <div class="tl-marker">
          <div
            class={`tl-dot${event.highlight ? ' tl-dot--hl' : ''}`}
            style={`background: ${fg};${event.highlight ? ` box-shadow: 0 0 0 4px ${bg};` : ''}`}
          />
          {!isLast && <div class="tl-stem" />}
        </div>
        <div class="tl-content">
          <div class="tl-date" style={`color: ${fg};`}>{event.date}</div>
          <div class="tl-title">{event.title}</div>
          {event.description && <div class="tl-desc">{event.description}</div>}
        </div>
      </div>
    );
  })}
</div>

<style>
  /* ================================================================
     VERTICAL LAYOUT (default)
     ================================================================ */
  .tl-container.tl-vertical {
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-surface);
    padding: 1.25rem;
    margin: 1rem 0;
  }

  .tl-vertical .tl-event {
    display: flex;
    gap: 0.875rem;
  }

  .tl-vertical .tl-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 1.5rem;
    flex-shrink: 0;
  }

  .tl-dot {
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    flex-shrink: 0;
    margin-top: 0.375rem;
  }

  .tl-dot--hl {
    width: 12px;
    height: 12px;
    margin-top: 0.25rem;
  }

  .tl-vertical .tl-stem {
    width: 2px;
    flex: 1;
    background: var(--color-border);
    margin-top: 0.375rem;
    min-height: 0.75rem;
  }

  .tl-vertical .tl-content {
    padding-bottom: 1.25rem;
  }

  .tl-vertical .tl-event--last .tl-content {
    padding-bottom: 0;
  }

  .tl-date {
    font-family: 'IBM Plex Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-bottom: 0.125rem;
  }

  .tl-title {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-text);
    line-height: 1.3;
  }

  .tl-desc {
    font-size: 0.775rem;
    color: var(--color-text-dim);
    line-height: 1.4;
    margin-top: 0.125rem;
  }

  /* ================================================================
     HORIZONTAL LAYOUT
     ================================================================ */
  .tl-container.tl-horizontal {
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-surface);
    padding: 1.25rem;
    margin: 1rem 0;
    overflow-x: auto;
    display: flex;
  }

  .tl-horizontal .tl-event {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 1;
    min-width: 8rem;
    position: relative;
  }

  .tl-horizontal .tl-marker {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 1.5rem;
    margin-bottom: 0.625rem;
  }

  .tl-horizontal .tl-stem {
    display: none;
  }

  /* Horizontal connecting line between dots */
  .tl-horizontal .tl-event:not(.tl-event--last)::after {
    content: '';
    position: absolute;
    top: 0.6875rem;
    left: 50%;
    width: 100%;
    height: 2px;
    background: var(--color-border);
    z-index: 0;
  }

  .tl-horizontal .tl-dot {
    position: relative;
    z-index: 1;
    margin-top: 0;
  }

  .tl-horizontal .tl-dot--hl {
    margin-top: 0;
  }

  .tl-horizontal .tl-content {
    padding: 0 0.5rem;
  }

  /* ================================================================
     RESPONSIVE: horizontal collapses to vertical on mobile
     ================================================================ */
  @media (max-width: 640px) {
    .tl-container.tl-horizontal {
      flex-direction: column;
      overflow-x: visible;
    }

    .tl-horizontal .tl-event {
      flex-direction: row;
      align-items: flex-start;
      text-align: left;
      min-width: auto;
      gap: 0.875rem;
    }

    .tl-horizontal .tl-event::after {
      display: none;
    }

    .tl-horizontal .tl-marker {
      flex-direction: column;
      width: 1.5rem;
      height: auto;
      margin-bottom: 0;
      flex-shrink: 0;
    }

    .tl-horizontal .tl-stem {
      display: block;
      width: 2px;
      flex: 1;
      background: var(--color-border);
      margin-top: 0.375rem;
      min-height: 0.75rem;
    }

    .tl-horizontal .tl-event--last .tl-stem {
      display: none;
    }

    .tl-horizontal .tl-dot {
      margin-top: 0.375rem;
    }

    .tl-horizontal .tl-dot--hl {
      margin-top: 0.25rem;
    }

    .tl-horizontal .tl-content {
      padding: 0;
      padding-bottom: 1.25rem;
    }

    .tl-horizontal .tl-event--last .tl-content {
      padding-bottom: 0;
    }
  }
</style>
