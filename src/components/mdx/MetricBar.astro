---
interface Props {
  title?: string;
  metrics: Array<{
    label: string;
    value: number;
    maxValue?: number;
    displayValue: string;
    color?: 'teal' | 'green' | 'amber' | 'rose';
  }>;
}

const { title, metrics } = Astro.props;

const fgColors: Record<string, string> = {
  teal:  '#0891b2',
  green: '#059669',
  amber: '#d97706',
  rose:  '#be123c',
};

const bgColors: Record<string, string> = {
  teal:  'rgba(8,145,178,0.18)',
  green: 'rgba(5,150,105,0.18)',
  amber: 'rgba(217,119,6,0.18)',
  rose:  'rgba(190,18,60,0.18)',
};

const globalMax = Math.max(...metrics.map((m) => m.value));

function getWidth(m: { value: number; maxValue?: number }): number {
  const max = m.maxValue || globalMax;
  return Math.min(100, Math.max(2, (m.value / max) * 100));
}
---

<div class="mb-container">
  {title && <div class="mb-title">{title}</div>}
  <div class="mb-rows">
    {metrics.map((m) => {
      const color = m.color || 'teal';
      const fg = fgColors[color];
      const bg = bgColors[color];
      const width = getWidth(m);

      return (
        <div class="mb-row">
          <div class="mb-label">{m.label}</div>
          <div class="mb-track">
            <div
              class="mb-fill"
              style={`width: ${width}%; background: linear-gradient(90deg, ${bg}, ${fg});`}
            />
          </div>
          <div class="mb-value" style={`color: ${fg};`}>{m.displayValue}</div>
        </div>
      );
    })}
  </div>
</div>

<style>
  .mb-container {
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-surface);
    padding: 1rem 1.25rem;
    margin: 1rem 0;
  }

  .mb-title {
    font-weight: 700;
    font-size: 0.8rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin-bottom: 0.875rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--color-border);
  }

  .mb-rows {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mb-row {
    display: grid;
    grid-template-columns: 7rem 1fr auto;
    gap: 0.75rem;
    align-items: center;
    padding: 0.375rem 0.5rem;
    border-radius: 0.375rem;
    transition: background 0.15s ease;
  }

  .mb-row:hover {
    background: var(--color-bg);
  }

  .mb-label {
    font-weight: 600;
    font-size: 0.8rem;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mb-track {
    height: 1.25rem;
    background: var(--color-bg);
    border-radius: 0.25rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .mb-fill {
    height: 100%;
    border-radius: 0.1875rem;
    min-width: 4px;
  }

  .mb-value {
    font-family: 'IBM Plex Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    white-space: nowrap;
    min-width: 4rem;
    text-align: right;
  }

  @media (max-width: 480px) {
    .mb-row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      gap: 0.25rem 0.75rem;
    }

    .mb-label {
      grid-column: 1 / 2;
      grid-row: 1;
    }

    .mb-value {
      grid-column: 2;
      grid-row: 1;
    }

    .mb-track {
      grid-column: 1 / -1;
      grid-row: 2;
    }
  }
</style>
