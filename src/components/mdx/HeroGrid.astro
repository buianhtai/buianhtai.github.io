---
interface Props {
  items: { label: string; sublabel: string; color: string }[];
}
const { items } = Astro.props;
---

<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 my-6">
  {items.map((item) => (
    <div class="text-center rounded-lg bg-[var(--color-surface)] border border-[var(--color-border)] p-5">
      <div class="text-2xl font-bold" style={`color: ${item.color};`}>{item.label}</div>
      <div class="text-xs text-[var(--color-text-dim)] mt-2 leading-relaxed">{item.sublabel}</div>
    </div>
  ))}
</div>
