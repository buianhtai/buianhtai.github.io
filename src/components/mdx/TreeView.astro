---
interface TreeNode {
  label: string;
  detail?: string;
  color?: 'teal' | 'green' | 'amber' | 'rose';
  children?: TreeNode[];
}

interface Props {
  root: TreeNode;
}

const { root } = Astro.props;

const fgColors: Record<string, string> = {
  teal:  '#0891b2',
  green: '#059669',
  amber: '#d97706',
  rose:  '#be123c',
};

const bgColors: Record<string, string> = {
  teal:  'rgba(8,145,178,0.12)',
  green: 'rgba(5,150,105,0.12)',
  amber: 'rgba(217,119,6,0.12)',
  rose:  'rgba(190,18,60,0.12)',
};

function esc(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

function renderBranch(children: TreeNode[], parentColor: string, depth: number): string {
  if (!children.length || depth > 4) return '';

  const lineColor = fgColors[parentColor] || fgColors.teal;
  let html = `<div class="tv-branch" style="--tv-line: ${lineColor};">`;

  children.forEach((child) => {
    const color = child.color || parentColor;
    const fg = fgColors[color] || fgColors.teal;

    html += `<div class="tv-node">`;
    html += `<div class="tv-card" style="border-left-color: ${fg};">`;
    html += `<span class="tv-label">${esc(child.label)}</span>`;
    if (child.detail) {
      html += `<span class="tv-detail">${esc(child.detail)}</span>`;
    }
    html += `</div>`;

    if (child.children && child.children.length > 0) {
      html += renderBranch(child.children, color, depth + 1);
    }

    html += `</div>`;
  });

  html += `</div>`;
  return html;
}

const rootColor = root.color || 'teal';
const childrenHtml = root.children
  ? renderBranch(root.children, rootColor, 1)
  : '';
---

<div class="tv-container">
  <div
    class="tv-root"
    style={`border-left-color: ${fgColors[rootColor]}; background: ${bgColors[rootColor]};`}
  >
    <span class="tv-label">{root.label}</span>
    {root.detail && <span class="tv-detail">{root.detail}</span>}
  </div>
  <Fragment set:html={childrenHtml} />
</div>

<style>
  .tv-container {
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-surface);
    padding: 1.25rem;
    margin: 1rem 0;
  }

  .tv-root {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.875rem;
    border-left: 3px solid;
    border-radius: 0.375rem;
  }

  .tv-branch {
    padding-left: 1.5rem;
    margin-left: 0.5rem;
  }

  .tv-node {
    position: relative;
    padding: 0.25rem 0;
  }

  /* Vertical line segment — non-last nodes: full height */
  .tv-node:not(:last-child)::before {
    content: '';
    position: absolute;
    left: -1.5rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--tv-line, var(--color-border));
  }

  /* Vertical line segment — last node: stops at connector */
  .tv-node:last-child::before {
    content: '';
    position: absolute;
    left: -1.5rem;
    top: 0;
    height: calc(0.25rem + 0.875rem);
    width: 2px;
    background: var(--tv-line, var(--color-border));
  }

  /* Horizontal connector */
  .tv-node::after {
    content: '';
    position: absolute;
    left: -1.5rem;
    top: calc(0.25rem + 0.875rem);
    width: 1.25rem;
    height: 2px;
    background: var(--tv-line, var(--color-border));
  }

  .tv-card {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-border);
    border-left: 2px solid;
    border-radius: 0.25rem;
    background: var(--color-bg);
  }

  .tv-label {
    font-weight: 600;
    font-size: 0.8rem;
    color: var(--color-text);
  }

  .tv-detail {
    font-family: 'IBM Plex Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    color: var(--color-text-dim);
  }

  @media (max-width: 480px) {
    .tv-branch {
      padding-left: 1rem;
      margin-left: 0.25rem;
    }

    .tv-node:not(:last-child)::before,
    .tv-node:last-child::before {
      left: -1rem;
    }

    .tv-node::after {
      left: -1rem;
      width: 0.75rem;
    }
  }
</style>
