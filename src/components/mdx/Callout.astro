---
interface Props {
  color?: 'teal' | 'green' | 'amber' | 'rose';
}
const { color = 'teal' } = Astro.props;

const styles = {
  teal:  'background: rgba(8,145,178,0.08); border-left: 3px solid #0891b2;',
  green: 'background: rgba(5,150,105,0.08); border-left: 3px solid #059669;',
  amber: 'background: rgba(217,119,6,0.08); border-left: 3px solid #d97706;',
  rose:  'background: rgba(190,18,60,0.08); border-left: 3px solid #be123c;',
};
---

<div
  class="rounded-md p-4 text-sm my-4 leading-relaxed"
  style={styles[color]}
>
  <slot />
</div>
