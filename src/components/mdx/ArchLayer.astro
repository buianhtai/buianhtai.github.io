---
interface Props {
  badge: string;
  badgeColor?: 'teal' | 'amber' | 'green' | 'rose';
  label: string;
  items: string[];
}
const { badge, badgeColor = 'teal', label, items } = Astro.props;

const bgColors = {
  teal:  'rgba(8,145,178,0.12)',
  green: 'rgba(5,150,105,0.12)',
  amber: 'rgba(217,119,6,0.12)',
  rose:  'rgba(190,18,60,0.12)',
};

const fgColors = {
  teal:  '#0891b2',
  green: '#059669',
  amber: '#d97706',
  rose:  '#be123c',
};
---

<div class="arch-layer">
  <div class="arch-badge" style={`background: ${bgColors[badgeColor]}; color: ${fgColors[badgeColor]};`}>
    {badge}
  </div>
  <div class="arch-body">
    <div class="arch-label">{label}</div>
    <div class="arch-chips">
      {items.map((item) => (
        <span class="arch-chip">{item}</span>
      ))}
    </div>
  </div>
</div>

<style>
  .arch-layer {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-surface);
    margin: 0.375rem 0;
  }

  .arch-badge {
    flex-shrink: 0;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-family: 'IBM Plex Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .arch-body {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
  }

  .arch-label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-text);
    white-space: nowrap;
    margin-right: 0.25rem;
  }

  .arch-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .arch-chip {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    font-family: 'IBM Plex Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    color: var(--color-text-dim);
    background: var(--color-bg);
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    .arch-layer {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>
